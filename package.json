{
  "name": "@danilqa/eslint-plugin-ts-pattern",
  "version": "0.0.1",
  "description": "ESLint plugin: warn when `if` is used on string-literal union types instead of ts-pattern's exhaustive `match`",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/rule-tester": "8.59.2",
    "@typescript-eslint/utils": "8.59.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "tsc-alias": "1.8.17",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.0.9"
}
